COMPOSE_PROJECT_NAME=simplyft

# Public host ports
FRONTEND_PORT=4200
BACKEND_PORT=8081
AI_SERVICE_PORT=8000
WHISPER_SERVICE_PORT=8001
OLLAMA_PORT=11435
POSTGRES_PORT=5432
CONTEXT_POSTGRES_PORT=5433
NGINX_PORT=8080

# Main PostgreSQL database used by Spring Boot
POSTGRES_IMAGE_TAG=16-alpine
POSTGRES_DB=simplyft
POSTGRES_USER=simplyft
POSTGRES_PASSWORD=change-me

# Separate PostgreSQL database used by AI context/memory
CONTEXT_POSTGRES_DB=simplyft_context
CONTEXT_POSTGRES_USER=simplyft_context
CONTEXT_POSTGRES_PASSWORD=change-me-context

# AI provider configuration
AI_PROVIDER=ollama
OLLAMA_IMAGE_TAG=latest
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=deepseek-r1
OPENAI_API_KEY=

# Reverse proxy
NGINX_IMAGE_TAG=1.27-alpine
